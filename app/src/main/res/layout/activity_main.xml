<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎬"
                android:textSize="48sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video Reminder"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pengingat otomatis saat buka TikTok/Instagram"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS IZIN"
                    android:textColor="#FF6B35"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <!-- Overlay Permission Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/tvOverlayStatus"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="✗"
                        android:textColor="#FF3B30"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Izin Tampil di Atas Aplikasi"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wajib untuk menampilkan overlay"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnOverlayPermission"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Aktifkan"
                        android:textSize="12sp"
                        android:backgroundTint="#FF6B35"
                        android:textColor="#FFFFFF" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A4A"
                    android:layout_marginVertical="12dp" />

                <!-- Accessibility Permission Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvAccessibilityStatus"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="✗"
                        android:textColor="#FF3B30"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Izin Accessibility Service"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Untuk mendeteksi app yang dibuka"
                            android:textColor="#888888"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnAccessibilityPermission"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Aktifkan"
                        android:textSize="12sp"
                        android:backgroundTint="#FF6B35"
                        android:textColor="#FFFFFF" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Video Reminder Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIDEO PENGINGAT"
                    android:textColor="#FF6B35"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <!-- Video Preview Area -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="12dp"
                    android:background="#0D0D1A"
                    android:layout_marginBottom="12dp">

                    <VideoView
                        android:id="@+id/videoPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <LinearLayout
                        android:id="@+id/llNoVideo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📹"
                            android:textSize="36sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Belum ada video dipilih"
                            android:textColor="#666666"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvVideoPath"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pilih video MP4 dari storage kamu"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"
                    android:ellipsize="middle"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btnPickVideo"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="📂  Pilih Video MP4"
                    android:backgroundTint="#FF6B35"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Pesan Pengingat -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PESAN PENGINGAT"
                    android:textColor="#FF6B35"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <EditText
                    android:id="@+id/etReminderTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Judul (contoh: STOP! Kamu harus besuk sekarang!)"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:inputType="text"
                    android:background="#0D0D1A"
                    android:padding="12dp"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etReminderMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Pesan (contoh: TikTok bisa nanti, besuk tidak bisa ditunda!)"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:background="#0D0D1A"
                    android:padding="12dp"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Target Apps Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APLIKASI TARGET"
                    android:textColor="#FF6B35"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overlay muncul saat buka aplikasi ini:"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp" />

                <!-- TikTok toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎵  TikTok"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <Switch
                        android:id="@+id/switchTikTok"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="#FF6B35"
                        android:trackTint="#553020" />
                </LinearLayout>

                <!-- Instagram toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📸  Instagram"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <Switch
                        android:id="@+id/switchInstagram"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="#FF6B35"
                        android:trackTint="#553020" />
                </LinearLayout>

                <!-- YouTube toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="▶️  YouTube"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <Switch
                        android:id="@+id/switchYouTube"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:thumbTint="#FF6B35"
                        android:trackTint="#553020" />
                </LinearLayout>

                <!-- Twitter toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🐦  X (Twitter)"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                    <Switch
                        android:id="@+id/switchTwitter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:thumbTint="#FF6B35"
                        android:trackTint="#553020" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Waktu Aktif Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AKTIFKAN REMINDER"
                        android:textColor="#FF6B35"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <Switch
                        android:id="@+id/switchMasterEnable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:thumbTint="#34C759"
                        android:trackTint="#1A3A22" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvMasterStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚫ Reminder tidak aktif"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tombol Simpan -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="💾  SIMPAN PENGATURAN"
            android:backgroundTint="#FF6B35"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Test Overlay Button -->
        <Button
            android:id="@+id/btnTest"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🧪  Test Tampilkan Overlay"
            android:backgroundTint="#0F3460"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="30dp" />

    </LinearLayout>
</ScrollView>
