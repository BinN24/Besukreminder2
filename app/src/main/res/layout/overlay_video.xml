<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <!-- Konten Overlay - style seperti notifikasi/tab Windows -->
    <LinearLayout
        android:id="@+id/overlayContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#1A1A2E"
        android:elevation="24dp">

        <!-- Handle bar (bisa di-drag) -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#555555"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp" />

        <!-- Header Bar - seperti Windows tab notification -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <!-- Ikon peringatan berkedip -->
            <TextView
                android:id="@+id/tvWarningIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvOverlayTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STOP! Kamu harus besuk sekarang!"
                    android:textColor="#FFD93D"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOverlayMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TikTok bisa nanti, ini tidak bisa ditunda!"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Tombol tutup -->
            <TextView
                android:id="@+id/tvClose"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:gravity="center"
                android:background="#333355"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Divider merah -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#FF3B30" />

        <!-- Video Player Area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#000000">

            <VideoView
                android:id="@+id/overlayVideoView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <!-- Play/Pause overlay button -->
            <TextView
                android:id="@+id/tvPlayPause"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="▶"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:gravity="center"
                android:background="#88000000"
                android:layout_gravity="center"
                android:visibility="gone" />

            <!-- Volume indicator -->
            <TextView
                android:id="@+id/tvVideoStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊 Video Pengingat"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:background="#AA000000"
                android:padding="6dp"
                android:layout_gravity="bottom|start"
                android:layout_margin="8dp" />
        </FrameLayout>

        <!-- Tombol Aksi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:weightSum="2">

            <!-- Tombol Pergi sekarang -->
            <Button
                android:id="@+id/btnGoNow"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="✅ Pergi Sekarang"
                android:backgroundTint="#34C759"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <!-- Tombol Snooze (tunda 15 menit) -->
            <Button
                android:id="@+id/btnSnooze"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="⏰ Tunda 15 Mnt"
                android:backgroundTint="#FF9500"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Tombol Abaikan Hari Ini -->
        <Button
            android:id="@+id/btnDismiss"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Abaikan untuk hari ini"
            android:backgroundTint="#2A2A4A"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</FrameLayout>
